# Application Settings
DEBUG=False

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Authentication configuration
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Facebook / Meta Graph API (Lead Ads import)
# Never commit real tokens. Put them into your local `.env` only.
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_LEADGEN_FORM_ID=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
FACEBOOK_PAGE_ID=990389240822813
FACEBOOK_POLL_INTERVAL_SECONDS=60
FACEBOOK_POLL_LOOKBACK_SECONDS=86400
FACEBOOK_IMPORT_LIMIT_PER_FORM=50
